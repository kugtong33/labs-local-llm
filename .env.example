# Local LLM Setup — Environment Configuration
# Copy this file to .env and adjust values for your machine.
# .env is gitignored and will never be committed.

# ── Model ────────────────────────────────────────────────────────────────────
# Which model to run. Must match an id in models/registry.conf
# Supported values: deepseek-v3 | glm-4 | minimax-m1
MODEL_NAME=glm-4

# ── Hardware mode ─────────────────────────────────────────────────────────────
# How the container uses compute resources.
# auto: detect GPU automatically, fall back to CPU if not available
# gpu:  require NVIDIA GPU (NVIDIA Container Toolkit must be installed)
# cpu:  CPU-only inference (slower, but works on any machine)
MODE=auto

# ── Networking ────────────────────────────────────────────────────────────────
# Host port the inference server binds to.
# AI coding agents connect to: http://localhost:$LLM_PORT/v1
LLM_PORT=11434

# ── GPU configuration (GPU mode only) ─────────────────────────────────────────
# NVIDIA GPU device index to use. 0 = first GPU, 1 = second GPU, etc.
# Only used when MODE=gpu or MODE=auto resolves to gpu.
GPU_DEVICE_ID=0

# ── Model storage ─────────────────────────────────────────────────────────────
# Absolute path on the host where model weights are stored.
# This directory is bind-mounted into the container as the Ollama model cache.
# Requires several GB to hundreds of GB depending on the model:
#   glm-4:        ~5.5 GB
#   qwen3-coder:  ~6 GB
#   deepseek-v3:  ~200 GB+ (GGUF Q2_K)
#   minimax-m1:   ~40 GB+ (experimental)
#
# Default: ~/.local/share/llm-models (set automatically by provision.sh)
# You only need to set this if you want a custom location. Use an absolute path —
# shell variables like $HOME and ~ are not expanded by Docker Compose.
# Example: MODEL_CACHE_DIR=/data/llm-models
#MODEL_CACHE_DIR=~/.local/share/llm-models

# ── HuggingFace token (optional) ──────────────────────────────────────────────
# Required only for gated/private models on HuggingFace.
# Leave empty for all models in this setup (they are publicly available).
HF_TOKEN=
